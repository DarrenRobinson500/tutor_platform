{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "python manage.py collectstatic --noinput --no-input --clear"
  },
  "deploy": {
    "startCommand": "python manage.py migrate && gunicorn main.wsgi:application --bind 0.0.0.0:$PORT"
  }
}